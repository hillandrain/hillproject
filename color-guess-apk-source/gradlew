#!/bin/sh
##############################################################################
## Gradle start up script
##############################################################################

# Attempt to set APP_HOME
APP_HOME="$(cd "$(dirname "$0")" && pwd)"

# Use the maximum available, or set MAX_FD != -1 to use that value
MAX_FD="maximum"

warn() {
    echo "$*"
}

die() {
    echo "$*"
    exit 1
}

# OS specific support
native_path() { echo "$1"; }

case "$(uname)" in
    CYGWIN*)
        native_path() { cygpath --path --windows "$1"; }
        ;;
esac

# Collect all arguments for the gradle command
set --     "$@"

# Execute Gradle
exec "${APP_HOME}/gradle/wrapper/gradle-wrapper.jar" "$@" 2>&1 || \
    exec java -jar "${APP_HOME}/gradle/wrapper/gradle-wrapper.jar" "$@" 2>&1
